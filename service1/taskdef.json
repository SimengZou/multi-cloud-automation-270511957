{
    "containerDefinitions": [
        {
            "name": "service1",
            "image": "<IMAGE1_NAME>",
            "portMappings": [
                {
                    "containerPort": 3000,
                    "hostPort": 3000
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/service1",
                    "awslogs-region": "ap-southeast-2",
                    "awslogs-stream-prefix": "service1"
                }
            }
        }
    ],
    "family": "service1",
    "requiresCompatibilities": ["FARGATE"],
    "networkMode": "awsvpc",
    "cpu": "256",
    "memory": "512",
    "executionRoleArn": "arn:aws:iam::084375558696:role/ecs-execution-role-simeng"
}