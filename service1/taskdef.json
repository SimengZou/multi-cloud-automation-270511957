{
  "containerDefinitions": [
    {
      "name": "service1",
      "image": "<IMAGE1_NAME>",
      "portMappings": [
        {
          "hostPort": 3000,
          "protocol": "tcp",
          "containerPort": 3000
        }
      ],
      "essential": true
    }
  ],
  "family": "service1",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::084375558696:role/ecs-execution-role-simeng",
  "taskRoleArn": "arn:aws:iam::084375558696:role/ecs-execution-role-simeng"
}